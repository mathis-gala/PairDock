{
  "name": "pairdock",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:web": "npm run dev --workspace @pairdock/web",
    "dev:api": "npm run dev --workspace @pairdock/api",
    "dev:agent": "npm run dev --workspace @pairdock/local-agent"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
