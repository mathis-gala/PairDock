# Omit IMAGE_TAG to deploy latest. Set IMAGE_TAG=v1.2.3 for a pinned release.
# IMAGE_TAG=v1.2.3

# Published releases use ghcr.io/<repository-owner>. Keep this value without a trailing slash.
PAIRDOCK_IMAGE_REPOSITORY=ghcr.io/replace-with-owner-or-organization

# Public deployment addresses. These examples are intentionally non-production domains.
PAIRDOCK_WEB_DOMAIN=pairdock.example.com
PAIRDOCK_API_DOMAIN=api.pairdock.example.com
PAIRDOCK_WEB_URL=https://pairdock.example.com
PAIRDOCK_API_URL=https://api.pairdock.example.com
GITHUB_REDIRECT_URI=https://api.pairdock.example.com/auth/developer/callback
SLACK_REDIRECT_URI=https://api.pairdock.example.com/auth/pm/callback

# Generate each value independently with: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-url-safe-random-value
AUTH_TOKEN_SECRET=replace-with-at-least-32-random-bytes
AUTH_STATE_SECRET=replace-with-at-least-32-random-bytes
AGENT_AUTH_TOKEN=replace-with-at-least-32-random-bytes

GITHUB_APP_ID=replace-me
GITHUB_APP_SLUG=replace-me
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me
# Store PEM on one line with literal \n separators.
GITHUB_APP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----

SLACK_CLIENT_ID=replace-me
SLACK_CLIENT_SECRET=replace-me
